# Copy to .env and fill in. Loaded by run.sh / the launchd plist.

# Stream to sample. 192 kbps is plenty for recognition; 320 gives no meaningful
# accuracy gain and just uses more bandwidth.
WXDU_STREAM_URL=https://stream.wxdu.art/wxdu192.mp3

# The wxdu API ingest endpoint. NOTE: api.wxdu.art (the Node API via nginx), NOT
# wxdu.art (that's the Cloudflare Pages frontend and won't accept POSTs).
WXDU_SHAZAM_API=https://api.wxdu.art/api/shazam

# Shared secret -- MUST match SHAZAM_INGEST_SECRET in the wxdu API's .env.
# Generate one with: openssl rand -hex 32
WXDU_SHAZAM_SECRET=

# Pause between attempts while a track is identified. Relaxed -- the song's
# already known, so there's no rush; keeps things gentle on Shazam.
WXDU_INTERVAL=23

# Pause between attempts during a miss/gap (when it can't identify what's on
# air). Short, so it catches the next track quickly. The 12s gap capture floors
# the real cadence at ~15s regardless, so going much below ~4 gains little.
WXDU_INTERVAL_GAP=4

# Adaptive capture length. It starts at FAST; any hit keeps it fast, a miss
# escalates to SLOW until the next hit. FAST = quick/cheap while a track is
# identified; SLOW = more audio to catch a hard-to-ID new track.
WXDU_CAPTURE_FAST=6
WXDU_CAPTURE_SLOW=12
